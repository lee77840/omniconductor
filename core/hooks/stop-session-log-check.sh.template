#!/usr/bin/env bash
#
# CONDUCTOR universal hook template
# hook_id: stop-session-log-check
# trigger: stop
# action: Block stop when recent commits exist but CURRENT_WORK.md or specs are stale.
# compile_targets: claude,codex
# fallback: rule-text-reminder
#
# Generated by adapters/<tool>/transform.sh.
#
# Enforces:
#   - operations.md O2 (CURRENT_WORK.md must update when work happens)
#   - spec-as-you-go.md W3 (source change → spec update in same turn)
#
# Exit code meaning in Stop hooks (Claude Code):
#   0 with no JSON output      → allow stop (default)
#   0 with {"decision":"block"} → inject reason, continue turn

set -u

# Placeholders filled by adapters/<tool>/transform.sh:
#   ${CONDUCTOR_PROJECT_DIR}       — absolute path to project root
#   ${CONDUCTOR_STALE_MINUTES}     — staleness threshold (default 30)
#   ${CONDUCTOR_COOLDOWN_SECONDS}  — cool-down between reminders (default 600)
#   ${CONDUCTOR_SOURCE_GLOB}       — file extensions tracked as source (default ts|tsx)
#   ${CONDUCTOR_SPEC_PATH}         — path prefix that counts as spec update (default docs/specs/)
#   ${CONDUCTOR_PLAN_THRESHOLD}    — source-file count above which a .plan.md is required (default 5)

REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
cd "$REPO_ROOT" || exit 0

CURRENT_WORK="${CONDUCTOR_CURRENT_WORK_PATH:-}"
PROFILE=".conductor/project.json"
if [ -z "$CURRENT_WORK" ] && [ -f "$PROFILE" ] && command -v /usr/bin/python3 >/dev/null 2>&1; then
  CURRENT_WORK="$(/usr/bin/python3 -c 'import json; print(json.load(open(".conductor/project.json")).get("current_work_path", ""))' 2>/dev/null || true)"
fi
CURRENT_WORK="${CURRENT_WORK:-docs/CURRENT_WORK.md}"
[ -f "$CURRENT_WORK" ] || exit 0

STALE_MINUTES="${CONDUCTOR_STALE_MINUTES:-30}"
COOLDOWN="${CONDUCTOR_COOLDOWN_SECONDS:-600}"
SRC_GLOB="${CONDUCTOR_SOURCE_GLOB:-}"
SPEC_PATH="${CONDUCTOR_SPEC_PATH:-}"
PLAN_THRESHOLD="${CONDUCTOR_PLAN_THRESHOLD:-}"
if [ -f "$PROFILE" ] && command -v /usr/bin/python3 >/dev/null 2>&1; then
  PROFILE_VALUES="$(/usr/bin/python3 -c '
import json
try:
    p=json.load(open(".conductor/project.json"))
    print("SRC="+"|".join(p.get("source_extensions", [])))
    print("SPEC="+((p.get("spec_paths") or [""])[0].rstrip("/")+"/"))
    print("PLAN="+str((p.get("thresholds") or {}).get("plan_source_files", "")))
except Exception:
    pass
' 2>/dev/null || true)"
  while IFS='=' read -r key value; do
    case "$key" in
      SRC) [ -z "$SRC_GLOB" ] && SRC_GLOB="$value" ;;
      SPEC) [ -z "$SPEC_PATH" ] && SPEC_PATH="$value" ;;
      PLAN) [ -z "$PLAN_THRESHOLD" ] && PLAN_THRESHOLD="$value" ;;
    esac
  done <<EOF
$PROFILE_VALUES
EOF
fi
SRC_GLOB="${SRC_GLOB:-ts|tsx}"
SPEC_PATH="${SPEC_PATH:-docs/specs/}"
PLAN_THRESHOLD="${PLAN_THRESHOLD:-5}"

RECENT_COMMITS=$(git log --since="${STALE_MINUTES} minutes ago" --oneline 2>/dev/null | /usr/bin/wc -l | /usr/bin/tr -d ' ')
if [ "$RECENT_COMMITS" -eq 0 ]; then
  exit 0
fi

# Cool-down: avoid double-reminding within COOLDOWN seconds.
FLAG="/tmp/conductor-stop-doc-flag-${USER:-unknown}"
if [ -f "$FLAG" ]; then
  LAST=$(cat "$FLAG" 2>/dev/null || echo 0)
  NOW=$(date +%s)
  DELTA=$((NOW - LAST))
  if [ "$DELTA" -lt "$COOLDOWN" ]; then
    exit 0
  fi
fi

# Check 1: CURRENT_WORK.md freshness.
WORK_STALE=0
if [ -z "$(/usr/bin/find "$CURRENT_WORK" -mmin -"${STALE_MINUTES}" 2>/dev/null)" ]; then
  WORK_STALE=1
fi

# Check 2: Spec-as-you-go (source files changed but no spec touched).
SPEC_STALE=0
SRC_CHANGES=$(git diff --name-only HEAD~"${RECENT_COMMITS}"..HEAD 2>/dev/null | /usr/bin/awk -v re="\\.(${SRC_GLOB})$" '$0 ~ re {n++} END{print n+0}')
SPEC_CHANGES=$(git diff --name-only HEAD~"${RECENT_COMMITS}"..HEAD 2>/dev/null | /usr/bin/awk -v p="${SPEC_PATH}" 'index($0,p){n++} END{print n+0}')
if [ "$SRC_CHANGES" -gt 3 ] && [ "$SPEC_CHANGES" -eq 0 ]; then
  SPEC_STALE=1
fi

# Check 3: Plan-first (W1.1) — Medium/Large scope source changes require a .plan.md.
# Mirrors the reference adopter's stop-session-log-check Check 4. Per workflow.md W1.1,
# 5+ source-file changes signal Medium scope or larger; orchestrator must produce a .plan.md
# before implementation. Hook fires post-hoc when no plan file exists in the diff.
PLAN_STALE=0
PLAN_CHANGES=$(git diff --name-only HEAD~"${RECENT_COMMITS}"..HEAD 2>/dev/null | /usr/bin/awk '/\.plan\.md$|^docs\/plans\/|^docs\/PLANS\.md$/{n++} END{print n+0}')
if [ "$SRC_CHANGES" -ge "$PLAN_THRESHOLD" ] && [ "$PLAN_CHANGES" -eq 0 ]; then
  PLAN_STALE=1
fi

REASONS=""
if [ "$WORK_STALE" -eq 1 ]; then
  REASONS="${REASONS}[CURRENT_WORK.md stale] Update docs/CURRENT_WORK.md with session log. "
fi
if [ "$SPEC_STALE" -eq 1 ]; then
  REASONS="${REASONS}[SPEC-AS-YOU-GO] ${SRC_CHANGES} source files changed but 0 spec files updated. Update relevant ${SPEC_PATH}*.md files to reflect new/changed features. "
fi
if [ "$PLAN_STALE" -eq 1 ]; then
  REASONS="${REASONS}[PLAN-FIRST] ${SRC_CHANGES} source files changed (>=${PLAN_THRESHOLD}) with no .plan.md in diff. Per workflow.md W1.1, Medium/Large scope requires a .plan.md before implementation. Add one retroactively or split the change. "
fi

# Check 4: structured CURRENT_WORK identity must match the actual worktree. The
# fields are optional for legacy documents and placeholders on a fresh install.
clean_state_value() {
  printf '%s' "$1" | /usr/bin/sed -E 's/^[[:space:]]*`?//; s/`?[[:space:]]*$//'
}
state_field() {
  /usr/bin/sed -n -E "s/^[*-]?[[:space:]]*(\\*\\*)?$1(\\*\\*)?[[:space:]]*:[[:space:]]*(.*)$/\\3/p" "$CURRENT_WORK" | /usr/bin/head -n 1
}
is_real_state() {
  [ -n "$1" ] && ! printf '%s' "$1" | /usr/bin/grep -qiE '^(<|\(|unknown|unset|none|todo|auto)'
}

RECORDED_BRANCH="$(clean_state_value "$(state_field active_branch)")"
RECORDED_BASE="$(clean_state_value "$(state_field base_sha)")"
RECORDED_HEAD="$(clean_state_value "$(state_field last_verified_head)")"
REAL_BRANCH="$(git branch --show-current 2>/dev/null || true)"
REAL_HEAD="$(git rev-parse HEAD 2>/dev/null || true)"

if is_real_state "$RECORDED_BRANCH" && [ "$RECORDED_BRANCH" != "$REAL_BRANCH" ]; then
  REASONS="${REASONS}[WORK-STATE DRIFT] CURRENT_WORK active_branch=${RECORDED_BRANCH}, actual branch=${REAL_BRANCH}. "
fi
if is_real_state "$RECORDED_BASE" && ! git merge-base --is-ancestor "$RECORDED_BASE" HEAD >/dev/null 2>&1; then
  REASONS="${REASONS}[WORK-STATE DRIFT] base_sha=${RECORDED_BASE} is not an ancestor of HEAD. "
fi
if is_real_state "$RECORDED_HEAD"; then
  case "$REAL_HEAD" in "$RECORDED_HEAD"*) : ;; *) REASONS="${REASONS}[WORK-STATE DRIFT] last_verified_head=${RECORDED_HEAD}, actual HEAD=${REAL_HEAD}. " ;; esac
fi

if [ -z "$REASONS" ]; then
  exit 0
fi

date +%s > "$FLAG"

/bin/cat <<JSON
{"decision":"block","reason":"[stop-hook] ${RECENT_COMMITS} commit(s) in last ${STALE_MINUTES} min. ${REASONS}Per universal-rules/operations.md O2 + spec-as-you-go.md W3 + workflow.md W1.1."}
JSON
